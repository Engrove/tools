{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tonearm-observation-package-v1/package.schema.json",
  "$defs": {
    "ValidationIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]{2,127}$"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "ValidationState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "schema_id",
        "validator_name",
        "validator_version",
        "validated_at",
        "errors"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_validated", "valid", "invalid"]
        },
        "schema_id": {
          "const": "engrove_tonearm_observation_package_v1"
        },
        "validator_name": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            }
          ]
        },
        "validator_version": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          ]
        },
        "validated_at": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "shared.schema.json#/$defs/DateTime"
            }
          ]
        },
        "errors": {
          "type": "array",
          "maxItems": 4096,
          "items": {
            "$ref": "#/$defs/ValidationIssue"
          }
        }
      }
    }
  },
  "title": "Engrove tonearm observation package v1",
  "description": "Repository-owned transfer contract for multi-view tonearm observations, camera state, semantics, uncertainty, provenance, validation, and neutral operator decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "package_id",
    "capture_set_id",
    "object",
    "target_consumer",
    "object_frame",
    "views",
    "landmarks",
    "observations",
    "stations",
    "features",
    "constraints",
    "uncertainty_model",
    "provenance",
    "validation",
    "operator_acceptance"
  ],
  "properties": {
    "schema": {
      "const": "engrove_tonearm_observation_package_v1"
    },
    "version": {
      "const": "1.0.0"
    },
    "package_id": {
      "$ref": "shared.schema.json#/$defs/Id"
    },
    "capture_set_id": {
      "$ref": "shared.schema.json#/$defs/Id"
    },
    "object": {
      "$ref": "object.schema.json#/$defs/ObjectRecord"
    },
    "target_consumer": {
      "$ref": "object.schema.json#/$defs/TargetConsumer"
    },
    "object_frame": {
      "$ref": "object-frame.schema.json#/$defs/ObjectFrame"
    },
    "views": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "view.schema.json#/$defs/View"
      }
    },
    "landmarks": {
      "type": "array",
      "maxItems": 4096,
      "items": {
        "$ref": "relations.schema.json#/$defs/Landmark"
      }
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": {
        "$ref": "observation.schema.json#/$defs/Observation"
      }
    },
    "stations": {
      "type": "array",
      "maxItems": 1024,
      "items": {
        "$ref": "relations.schema.json#/$defs/Station"
      }
    },
    "features": {
      "type": "array",
      "maxItems": 2048,
      "items": {
        "$ref": "relations.schema.json#/$defs/Feature"
      }
    },
    "constraints": {
      "type": "array",
      "maxItems": 2048,
      "items": {
        "$ref": "relations.schema.json#/$defs/Constraint"
      }
    },
    "uncertainty_model": {
      "$ref": "uncertainty.schema.json#/$defs/UncertaintyModel"
    },
    "provenance": {
      "$ref": "provenance.schema.json#/$defs/Provenance"
    },
    "validation": {
      "$ref": "#/$defs/ValidationState"
    },
    "operator_acceptance": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "decision.schema.json#/$defs/OperatorAcceptance"
        }
      ]
    }
  }
}
