{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tonearm-observation-package-v1/provenance.schema.json",
  "$defs": {
    "ProvenanceEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_id",
        "entity_type",
        "label",
        "uri",
        "sha256",
        "created_at"
      ],
      "properties": {
        "entity_id": {
          "$ref": "shared.schema.json#/$defs/Id"
        },
        "entity_type": {
          "type": "string",
          "enum": [
            "image",
            "svg",
            "json",
            "operator_note",
            "calibration_reference",
            "software_output",
            "other"
          ]
        },
        "label": {
          "$ref": "shared.schema.json#/$defs/Name"
        },
        "uri": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 2048
            }
          ]
        },
        "sha256": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          ]
        },
        "created_at": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "shared.schema.json#/$defs/DateTime"
            }
          ]
        }
      }
    },
    "ProvenanceAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "agent_type", "name", "version"],
      "properties": {
        "agent_id": {
          "$ref": "shared.schema.json#/$defs/Id"
        },
        "agent_type": {
          "$ref": "shared.schema.json#/$defs/AgentType"
        },
        "name": {
          "$ref": "shared.schema.json#/$defs/Name"
        },
        "version": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          ]
        }
      }
    },
    "ProvenanceActivity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activity_id",
        "activity_type",
        "started_at",
        "ended_at",
        "agent_ids",
        "used_entity_ids",
        "generated_entity_ids"
      ],
      "properties": {
        "activity_id": {
          "$ref": "shared.schema.json#/$defs/Id"
        },
        "activity_type": {
          "type": "string",
          "enum": [
            "capture",
            "rectification",
            "tracing",
            "measurement",
            "calculation",
            "annotation",
            "validation",
            "other"
          ]
        },
        "started_at": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "shared.schema.json#/$defs/DateTime"
            }
          ]
        },
        "ended_at": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "$ref": "shared.schema.json#/$defs/DateTime"
            }
          ]
        },
        "agent_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "shared.schema.json#/$defs/Id"
          }
        },
        "used_entity_ids": {
          "type": "array",
          "maxItems": 4096,
          "items": {
            "$ref": "shared.schema.json#/$defs/Id"
          }
        },
        "generated_entity_ids": {
          "type": "array",
          "maxItems": 4096,
          "items": {
            "$ref": "shared.schema.json#/$defs/Id"
          }
        }
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entities", "activities", "agents"],
      "properties": {
        "entities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4096,
          "items": {
            "$ref": "#/$defs/ProvenanceEntity"
          }
        },
        "activities": {
          "type": "array",
          "maxItems": 4096,
          "items": {
            "$ref": "#/$defs/ProvenanceActivity"
          }
        },
        "agents": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/ProvenanceAgent"
          }
        }
      }
    }
  }
}
