{
  "name": "engrove-tools-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Hub and deterministic SEO/AI registry compiler for Engrove browser tools.",
  "type": "module",
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "build:apps": "node scripts/build.mjs",
    "build:seo": "node scripts/compile-seo.mjs",
    "build": "npm run build:apps && npm run build:seo",
    "dev": "npm run build && node scripts/serve.mjs",
    "check": "node scripts/check-seo.mjs",
    "check:schema": "node scripts/check-seo.mjs",
    "check:registry": "node scripts/check-seo.mjs",
    "check:routes": "node scripts/check-seo.mjs",
    "check:html": "node scripts/check-seo.mjs",
    "check:canonical": "node scripts/check-seo.mjs",
    "check:structured-data": "node scripts/check-seo.mjs",
    "check:sitemap": "node scripts/check-seo.mjs",
    "check:robots": "node scripts/check-seo.mjs",
    "check:agent-files": "node scripts/check-seo.mjs",
    "check:agent-parity": "node scripts/check-seo.mjs",
    "check:claims": "node scripts/check-seo.mjs",
    "check:preview-policy": "node scripts/check-seo.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:sanitation": "npm run clean && npm run build && npm run check:seo"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "license": "Unlicense"
}
