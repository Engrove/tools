{
  "name": "engrove-tools-hub",
  "version": "1.1.0",
  "private": true,
  "description": "Deterministic static hub and SEO/AI-discovery compiler for Engrove browser tools.",
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs && node scripts/serve.mjs",
    "check": "node scripts/check-entry.mjs source",
    "check:schema": "node scripts/check-entry.mjs schema",
    "check:registry": "node scripts/check-entry.mjs registry",
    "check:routes": "node scripts/check-entry.mjs routes",
    "check:html": "node scripts/check-entry.mjs html",
    "check:canonical": "node scripts/check-entry.mjs canonical",
    "check:structured-data": "node scripts/check-entry.mjs structured-data",
    "check:sitemap": "node scripts/check-entry.mjs sitemap",
    "check:robots": "node scripts/check-entry.mjs robots",
    "check:agent-files": "node scripts/check-entry.mjs agent-files",
    "check:agent-parity": "node scripts/check-entry.mjs agent-parity",
    "check:claims": "node scripts/check-entry.mjs claims",
    "check:preview-policy": "node scripts/check-entry.mjs preview-policy",
    "check:determinism": "node scripts/check-entry.mjs determinism",
    "check:seo": "node scripts/check-entry.mjs seo",
    "check:sanitation": "npm run check && npm run build && npm run check:seo && npm run check:determinism"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "license": "Unlicense"
}
